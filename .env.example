# ============================================================
# 科技情报采集器 — 环境变量（复制为 .env 后填写真实值）
# ============================================================

# ── AI 沙盒（阶段 3 启用）OpenAI 兼容接口 ──
# 适配 DeepSeek / 通义千问 / 智谱 / OpenAI / Ollama 等任何 OpenAI 兼容端点
# 示例：
#   DeepSeek: AI_BASE_URL=https://api.deepseek.com/v1   AI_MODEL=deepseek-chat
#   通义:     AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1  AI_MODEL=qwen-plus
#   OpenAI:   AI_BASE_URL=https://api.openai.com/v1     AI_MODEL=gpt-4o-mini
AI_BASE_URL=https://api.example.com/v1
AI_API_KEY=sk-replace-me
AI_MODEL=your-model-name

# 可选：AI 调用控制
AI_TIMEOUT_MS=60000
# AI 参与度灰区阈值（qualityScore 落在此区间则进入人工"待复核"）
AI_REVIEW_LOW=0.4
AI_REVIEW_HIGH=0.7

# ── 通知（阶段 5 启用，可选）──
NOTIFY_WEBHOOK_URL=
